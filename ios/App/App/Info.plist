<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
        <string>Dash</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleIconName</key>
	<string>AppIcon</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>
	<!-- ATS exception for local relay testing on simulator (ws://localhost) -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<!-- Face ID gates app-lock unlock; the app-lock key in turn protects
	     access to encrypted notes (and, when sync is enabled, the vault
	     key stored in iOS Keychain). -->
	<key>NSFaceIDUsageDescription</key>
	<string>Dash uses Face ID to unlock the app and your encrypted notes.</string>
	<!-- Required to attach images from the photo library to notes. -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Dash uses the photo library so you can attach images to your notes.</string>
	<!-- Custom URL scheme so dashnotes://share/... and dashnotes://live#...
	     deep links delivered from Mail / iMessage / Safari open the app
	     and route through Capacitor's App.appUrlOpen event. Mirrors the
	     Electron protocol-handler registration in electron-main.js. -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>io.dashnote.app.deeplink</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>dashnotes</string>
			</array>
		</dict>
	</array>
	<!-- Export-compliance declaration: app uses standard published crypto
	     (AES-GCM, HKDF, HMAC, PBKDF2 via WebCrypto) which qualifies for the
	     mass-market exemption (ECCN 5D992.c). With this key set false, App
	     Store Connect skips the encryption questionnaire on every build. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
</dict>
</plist>
